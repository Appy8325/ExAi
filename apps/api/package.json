{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "Concourse NestJS 11 (Fastify) API deployable \u2014 the one API service serving first-party and public API traffic. Unscoped name per docs/37-monorepo-and-folder-structure.md \u00a76: apps are deploy targets, never imported by name.",
  "license": "UNLICENSED",
  "main": "./dist/main.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./serverless": {
      "types": "./dist/serverless.d.ts",
      "default": "./dist/serverless.js"
    }
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "nest build",
    "start": "node --env-file-if-exists=.env dist/main",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "openapi:emit": "echo \"openapi:emit -- real generation lands with the first real module, Milestone 1+\""
  },
  "dependencies": {
    "@nestjs/core": "^11.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "fastify": "^5.2.0",
    "drizzle-orm": "^0.38.2",
    "@concourse/ai": "workspace:*",
    "@concourse/database": "workspace:*",
    "@concourse/shared": "workspace:*",
    "@concourse/api-contract": "workspace:*",
    "@concourse/notifications": "workspace:*",
    "@concourse/flags": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@concourse/config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.2",
    "postgres": "^3.4.5",
    "eslint": "^9.17.0",
    "vitest": "^2.1.8"
  }
}
