{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "description": "Concourse Node 22 + BullMQ 5 worker deployable \u2014 the one worker service running every queue consumer, scheduled job, and the outbox relay. Unscoped name per docs/37-monorepo-and-folder-structure.md \u00a76: apps are deploy targets, never imported by name.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.2",
    "@concourse/ai": "workspace:*",
    "@concourse/database": "workspace:*",
    "@concourse/shared": "workspace:*",
    "@concourse/notifications": "workspace:*",
    "@concourse/flags": "workspace:*"
  },
  "devDependencies": {
    "@concourse/config": "workspace:*",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "eslint": "^9.17.0"
  }
}
