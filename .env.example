# Web (Vercel)
# Demonstration/pilot Vercel-only mode. Never enable for a public production release.
MVP_VERCEL_MODE=false
# Enables the in-memory activity simulator for /demo routes only.
DEMO_MODE=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API (required in production)
API_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
# Direct or session-pooler URL for schema migrations; do not use transaction mode on port 6543.
MIGRATION_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
API_SUPABASE_URL=https://your-project.supabase.co
API_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Reserved for future local JWT verification. The release API currently
# validates bearer tokens through Supabase Auth and does not require this.
API_SUPABASE_JWT_SECRET=your-supabase-jwt-secret
API_CORS_ORIGIN=http://localhost:3000
API_PUBLIC_WEB_ORIGIN=http://localhost:3000
API_PORT=3001

# Worker
WORKER_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
WORKER_REDIS_URL=redis://localhost:6379
WORKER_SUPABASE_URL=https://your-project.supabase.co
WORKER_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
WORKER_CLAMAV_HOST=localhost
WORKER_CLAMAV_PORT=3310

# Demo seed (use inboxes that can receive Supabase Magic Links in hosted environments)
DEMO_ORGANIZER_EMAIL=organizer@example.com
DEMO_EXHIBITOR_EMAIL=exhibitor@example.com

# NVIDIA Build AI
NVIDIA_API_KEY=your-nvidia-build-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Product analytics and observability
POSTHOG_API_KEY=your-posthog-project-key
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Billing
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# AWS SES and browser push
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:ops@example.com
