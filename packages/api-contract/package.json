{
  "name": "@concourse/api-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Zod→OpenAPI pipes + the committed OpenAPI 3.1 artifact (docs/18-api-architecture.md §2, docs/37-monorepo-and-folder-structure.md §6.5).",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openapi/concourse.v1.json": "./openapi/concourse.v1.json",
    "./src/exhibitor-dashboard": {
      "types": "./dist/exhibitor-dashboard.d.ts",
      "default": "./dist/exhibitor-dashboard.js"
    },
    "./src/relationship-workspace": {
      "types": "./dist/relationship-workspace.d.ts",
      "default": "./dist/relationship-workspace.js"
    },
    "./src/public-booth": {
      "types": "./dist/public-booth.d.ts",
      "default": "./dist/public-booth.js"
    }
  },
  "dependencies": {
    "zod": "^3.24.1",
    "@concourse/shared": "workspace:*"
  },
  "devDependencies": {
    "@concourse/config": "workspace:*",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
