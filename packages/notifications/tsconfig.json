{
  "$schema": "https://json.schemastore.org/tsconfig",
  // This package is not a Next.js app, but its templates are JSX/React Email
  // components (packages/notifications/src/templates/**), so the Next.js
  // tsconfig base — which enables the "react-jsx" transform and DOM libs — is
  // the closer fit vs. the plain node.json base, the same reasoning
  // packages/ui/tsconfig.json already documents for its own vendored Radix
  // components. See docs/37-monorepo-and-folder-structure.md §6.9 for the
  // available @concourse/config bases.
  "extends": "@concourse/config/typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
