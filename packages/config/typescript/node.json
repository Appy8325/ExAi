{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@concourse/config/typescript/node",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
