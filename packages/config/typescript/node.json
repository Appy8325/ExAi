{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@concourse/config/typescript/node",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    // Source and output directories belong to each consuming workspace. Relative
    // paths in an inherited config resolve from this package, not the consumer.
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
