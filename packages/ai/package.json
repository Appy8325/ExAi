{
  "name": "@concourse/ai",
  "version": "0.1.0",
  "private": true,
  "description": "AiModule \u2014 the sole boundary to configured AI providers (docs/21-ai-architecture.md \u00a71).",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "knowledge": ["dist/knowledge/index.d.ts"],
      "knowledge/security": ["dist/knowledge/upload-security.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge/index.d.ts",
      "default": "./dist/knowledge/index.js"
    },
    "./knowledge/security": {
      "types": "./dist/knowledge/upload-security.d.ts",
      "default": "./dist/knowledge/upload-security.js"
    }
  },
  "dependencies": {
    "@concourse/database": "workspace:*",
    "@concourse/shared": "workspace:*",
    "drizzle-orm": "^0.38.2",
    "fflate": "0.8.3",
    "pdf-parse": "2.4.5"
  },
  "devDependencies": {
    "@concourse/config": "workspace:*",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
