{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@concourse/api-client#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@concourse/ai#build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "@concourse/flags#build": { "dependsOn": ["^build"], "outputs": [] },
    "@concourse/notifications#build": { "dependsOn": ["^build"], "outputs": [] },
    "@concourse/ui#build": { "dependsOn": ["^build"], "outputs": [] },
    "lint": { "dependsOn": ["^build"] },
    "typecheck": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["build"] },
    "test:integration": { "dependsOn": ["build"], "cache": false },
    "e2e": { "dependsOn": ["build"], "cache": false },
    "clean": { "cache": false },
    "dev": { "cache": false, "persistent": true }
  }
}
