# =============================================================================
# ExAi (Concourse) — Production Environment Variables
# =============================================================================
# Copy this file to populate your production environment. Values below are
# placeholders — replace with real secrets before deploying.
# =============================================================================

# -- Web (Next.js 15 on Vercel) --
# Public Supabase project configuration for cookie-backed Auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_API_BASE_URL=https://api.exai.app

# -- API (NestJS 11 on Fastify, ECS Fargate) --
# Database: Supabase Postgres connection string (with pgvector).
API_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
MIGRATION_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# Supabase management endpoint and service role (server-side only, keep secret).
API_SUPABASE_URL=https://your-project.supabase.co
API_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# JWT secret for verifying Supabase-issued tokens (mirrors SUPABASE_JWT_SECRET in
# Supabase project dashboard → Settings → API → JWT Secret).
API_SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Allowed origins for CORS (comma-separated if multiple).
API_CORS_ORIGIN=https://exai.app
API_PUBLIC_WEB_ORIGIN=https://exai.app
# Port the API listens on (default 3001).
API_PORT=3001

# -- Worker (Node 22 + BullMQ, ECS Fargate) --
# Database: same Supabase Postgres (worker can use a different pooled connection).
WORKER_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
# Redis for BullMQ queueing (ElastiCache Redis in production).
WORKER_REDIS_URL=redis://your-elasticache-cluster.abcdef.ng.0001.use1.cache.amazonaws.com:6379

# -- AI Services (Anthropic Claude, VoyageAI) --
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key

# -- Feature Flags / Observability --
POSTHOG_API_KEY=phc_your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# -- Email (AWS SES) --
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAYOURACCESSKEY
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# -- Web Push (VAPID keys for browser notifications) --
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:ops@exai.app
